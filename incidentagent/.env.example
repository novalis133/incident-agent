# ===== Gradient/LLM Configuration =====
DIGITALOCEAN_API_TOKEN=your_digitalocean_token
GRADIENT_API_TOKEN=your_gradient_api_token
GRADIENT_MODEL_ACCESS_KEY=your_gradient_model_access_key

# Knowledge Base IDs (create in DO Gradient console)
GRADIENT_RUNBOOKS_KB_ID=
GRADIENT_INCIDENTS_KB_ID=

# Demo Mode (uses mock data for all data sources when true)
DEMO_MODE=true

# LLM Configuration
LLM_PROVIDER=gradient  # gradient, anthropic, openai
LLM_MODEL=claude-sonnet-4-20250514  # Model to use for inference
ANTHROPIC_API_KEY=  # Only if using anthropic directly

# ===== Data Sources Configuration =====
# For Docker: use service names (elasticsearch, prometheus)
# For local: use localhost
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_API_KEY=  # Optional
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme

PROMETHEUS_URL=http://prometheus:9090
KUBERNETES_CONFIG=/etc/kube/config

# ===== Optional Integrations =====
PAGERDUTY_API_KEY=
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# ===== Application Settings =====
LOG_LEVEL=INFO
DEBUG=false
ENVIRONMENT=development

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ===== Investigation Settings =====
CONFIDENCE_THRESHOLD=0.85
MAX_INVESTIGATION_TIME=300

# ===== Model Training =====
TRAINING_ENABLED=true
TRAINING_THRESHOLD=100
BENCHMARK_IMPROVEMENT_THRESHOLD=0.02

# ===== CORS Configuration =====
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000

# ===== Cache Configuration =====
CACHE_ENABLED=true
CACHE_TTL=3600

# ===== Rate Limiting =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
